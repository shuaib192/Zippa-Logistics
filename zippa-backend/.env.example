# ============================================
# 🎓 WHAT IS .env?
# .env is a file that stores SECRET configuration.
# Things like database passwords, API keys, etc.
# 
# WHY NOT PUT THESE IN CODE?
# Because code goes to GitHub (public!). Secrets
# should NEVER be in your code. .env is in .gitignore
# so it never gets uploaded.
#
# HOW TO USE THIS FILE:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values
# 3. Never share .env with anyone!
# ============================================

# Server Configuration
PORT=3000                    # Which port the server runs on
NODE_ENV=development         # 'development', 'test', or 'production'

# Database Configuration (PostgreSQL)
DB_HOST=localhost             # Where PostgreSQL is running
DB_PORT=5432                  # Default PostgreSQL port
DB_USER=zippa_admin           # Database username (you'll create this)
DB_PASSWORD=your_password     # Database password (change this!)
DB_NAME=zippa_logistics       # Database name

# JWT (JSON Web Tokens) - Used for login sessions
# Generate a random string for these (e.g., run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_EXPIRES_IN=1h             # Access token expires in 1 hour
JWT_REFRESH_EXPIRES_IN=7d     # Refresh token expires in 7 days

# Google Maps API Key (for distance calculation, geocoding)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Paystack API Keys (for payments) - Get from https://dashboard.paystack.com
PAYSTACK_SECRET_KEY=sk_test_your-key-here
PAYSTACK_PUBLIC_KEY=pk_test_your-key-here

# Google Gemini API Key (for AI chatbot)
GEMINI_API_KEY=your-gemini-api-key

# Firebase (for push notifications) - We'll set this up later
# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_CLIENT_EMAIL=
